#!/bin/sh
# Strip Cursor attribution from commit messages (commit-msg hook).
MSG_FILE="$1"
[ -f "$MSG_FILE" ] || exit 0
tmp="${MSG_FILE}.tmp"
grep -viE '^(co-authored-by:.*cursor|made-with:.*cursor)' "$MSG_FILE" > "$tmp" || true
# Drop trailing blank lines left after stripping trailers.
sed -i '/./,$!d' "$tmp" 2>/dev/null || sed -i '' '/./,$!d' "$tmp" 2>/dev/null || true
mv "$tmp" "$MSG_FILE"
exit 0
