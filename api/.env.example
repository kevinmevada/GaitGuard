API_HOST=0.0.0.0
API_PORT=8001
DEBUG=False

# CORS (required for production deployments)
# Comma-separated list of frontend origins allowed to call this API.
# Wildcards (*) are NOT supported — set your real frontend URL(s), e.g.:
#   CORS_ORIGINS=https://gaitguard.example.com,https://www.gaitguard.example.com
# If unset, only localhost dev origins are allowed (Render/Railway/Heroku must set this).
CORS_ORIGINS=http://localhost:8001,http://127.0.0.1:8001

MODEL_DIR=../fall_risk_pipeline/results/checkpoints
DATA_DIR=../fall_risk_pipeline/data

# Optional HMAC key for checkpoint tamper detection (recommended in production).
# Training and API must use the same value. SHA-256 manifest entries are always required.
# CHECKPOINT_HMAC_KEY=change-me-to-a-long-random-secret

LOG_LEVEL=INFO
