API_HOST=0.0.0.0
API_PORT=8001
DEBUG=False

# CORS (required for production deployments)
# Comma-separated list of frontend origins allowed to call this API.
# Wildcards (*) are NOT supported — set your real frontend URL(s), e.g.:
#   CORS_ORIGINS=https://gaitguard.example.com,https://www.gaitguard.example.com
# If unset, only localhost dev origins are allowed (Render/Railway/Heroku must set this).
CORS_ORIGINS=http://localhost:8001,http://127.0.0.1:8001

MODEL_DIR=../fall_risk_pipeline/results/checkpoints
DATA_DIR=../fall_risk_pipeline/data

# Required in production (SEC-009): HMAC ties manifest+pickle to a deployment secret.
# SHA-256 alone does not help if both manifest and pickle are replaced on the Hub.
# Training and API must use the same value; Hub artifacts must be signed with it.
# CHECKPOINT_HMAC_KEY=change-me-to-a-long-random-secret

# Pin immutable Hub revision for production downloads (SEC-009). Do not use "main".
# GAITGUARD_HF_REVISION=v1.0.0

# Optional shared secret for /predict (required when ENVIRONMENT=production).
# Programmatic / cross-origin clients send X-API-Key or Authorization: Bearer.
# Bundled browser UI at /app uses POST /app/predict (same-origin; no client-side key — SEC-006).
# For operator access control, prefer Cloudflare Access or Render auth in front of the service.
# GAITGUARD_API_KEY=change-me-to-a-long-random-secret

LOG_LEVEL=INFO

# Reverse-proxy rate limiting (SEC-008). Set true on Render/Railway so slowapi keys
# clients by X-Forwarded-For instead of the load-balancer TCP peer.
# TRUST_PROXY_HEADERS=true
# PREDICT_MAX_CONCURRENT=2
# PREDICT_REQUEST_TIMEOUT_SEC=120
# PREDICT_RATE_LIMIT=10/minute

# SEC-010: Swagger/ReDoc/OpenAPI are disabled when ENVIRONMENT=production.
# SEC-013: .env is not loaded when ENVIRONMENT=production; set secrets via the platform.
# ENABLE_API_DOCS=false
